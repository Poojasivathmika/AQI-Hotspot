# Environment Configuration for India Air Quality & HCHO Hotspot Intelligence

# Data Ingest Modes: 'offline', 'api', or 'local_csv'
GEE_DATA_SOURCE=offline
OPENAQ_DATA_SOURCE=offline
FIRMS_DATA_SOURCE=offline

# Local CSV Paths (Only used if the respective DATA_SOURCE is 'local_csv')
# E.g., GEE_LOCAL_CSV_PATH=C:/path/to/satellite/grid/folder or a single CSV file
GEE_LOCAL_CSV_PATH=
OPENAQ_LOCAL_CSV_PATH=
FIRMS_LOCAL_CSV_PATH=

# If api fetch fails, should it fallback to 'offline' mock generation?
FALLBACK_TO_OFFLINE=True

# API Keys
OPENAQ_API_KEY=
FIRMS_MAP_KEY=
ANTHROPIC_API_KEY=